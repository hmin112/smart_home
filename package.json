{
  "name": "smart-home-root",
  "version": "1.0.0",
  "description": "Smart Home Project Root",
  "scripts": {
    "install:main": "npm install --prefix main",
    "install:web": "npm install --prefix web",
    "install:all": "npm install --prefix main && npm install --prefix web",
    "dev": "npm run dev --prefix web",
    "start": "npm run start --prefix main",
    "start:main": "npm run start --prefix main",
    "dev:web": "npm run dev --prefix web",
    "build:web": "npm run build --prefix web",
    "setup:db": "bash main/setup_db.sh"
  }
}
